# Sentinel ZTNA — environment configuration (copy to .env and tweak)

ZTNA_API_HOST=0.0.0.0
ZTNA_API_PORT=8000

# Session lifetimes
ZTNA_SESSION_TTL_SECONDS=1800
ZTNA_SESSION_HARD_TTL_SECONDS=28800
ZTNA_MAX_FAILED_ATTEMPTS=5
ZTNA_SESSION_STORE_BACKEND=memory
ZTNA_REDIS_URL=redis://localhost:6379/0
ZTNA_REDIS_KEY_PREFIX=ztna

# Risk thresholds (0–100)
ZTNA_RISK_MONITOR_THRESHOLD=45
ZTNA_RISK_BLOCK_THRESHOLD=70

# ML — auto-train on startup when model.joblib is missing
ZTNA_ML_AUTO_TRAIN=true

# API auth (set true + token for production)
ZTNA_AUTH_ENABLED=false
ZTNA_AUTH_TOKEN=

# Observability and controls
ZTNA_METRICS_ENABLED=true
ZTNA_RATE_LIMIT_ENABLED=true
ZTNA_RATE_LIMIT_POSTURE_PER_MIN=30
ZTNA_RATE_LIMIT_ACCESS_PER_MIN=180

# Proxy → backend
ZTNA_PDP_URL=http://localhost:8000/api/access
ZTNA_LISTEN=0.0.0.0:9090
